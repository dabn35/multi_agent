import os
import logging
from dotenv import load_dotenv

load_dotenv()

# 로깅 설정
logging.basicConfig(level=logging.INFO, format='[%(levelname)s] %(message)s')

# LLM 사용 여부 (기본 False)
USE_LLM_REVIEW = os.getenv("USE_LLM_REVIEW", "False").lower() in ("1", "true", "yes")

# OpenAI 기본 모델
OPENAI_REVIEW_MODEL = os.getenv("OPENAI_REVIEW_MODEL", "gpt-5-mini")


def review_guides(guides):
    """검토 진입점: LLM 검토 사용 시 GROQ -> OpenAI -> 규칙 기반 순으로 시도.

    - Groq 호출 실패 시 OpenAI로 폴백.
    - OpenAI 호출 실패 시 기존 규칙 기반 `review_guides_with_rules`로 폴백.
    """
    if not USE_LLM_REVIEW:
        return review_guides_with_rules(guides)

    # 1) Groq 우선
    try:
        return review_guides_with_groq(guides)
    except Exception as e:
        logging.warning("[review_guides] Groq 검토 실패: %s", e)

    # 2) OpenAI 폴백
    try:
        return review_guides_with_openai(guides)
    except Exception as e:
        logging.warning("[review_guides] OpenAI 검토 실패: %s", e)

    # 3) 마지막으로 규칙 기반
    return review_guides_with_rules(guides)


def _build_llm_prompt(guides_text: str) -> str:
    """LLM 검토 프롬프트 생성: 요청한 4가지 기준을 포함한다."""
    prompt = (
        "다음 사용자 안내문을 검토하라. 응답은 한국어로 하며, JSON으로 결과를 반환하라.\n\n"
        "검토 기준:\n"
        "1) 입력 자료에 없는 내용을 단정하고 있지는 않은가? (예: 사실로 단정하는 문장)\n"
        "2) 핵심 정보(날짜, 대상, 행동 지시 등)가 빠지지는 않았는가?\n"
        "3) 사용자가 해야 할 일이 명확히 보이는가? (구체적 행동/다음 단계)\n"
        "4) 위험하거나 부적절한 표현(과장, 오해 소지, 안전 문제)이 있는가?\n\n"
        "출력 형식(예시):\n"
        "{\n"
        "  \"summary\": \"간단한 한줄 요약\",\n"
        "  \"issues\": [ {\"criterion\": 1, \"detail\": \"문제 설명\"}, ... ],\n"
        "  \"recommendation\": \"수정 권장사항 간단문장\"\n"
        "}\n\n"
        "검토 대상 텍스트:\n" + guides_text
    )
    return prompt


def review_guides_with_groq(guides):
    """Groq API(또는 langchain_groq)를 사용해 안내문을 검토한다.

    - `GROQ_API_KEY`를 환경변수 또는 .env에서 읽어온다.
    - 라이브러리 또는 호출 오류가 나면 예외를 발생시켜 폴백하도록 한다.
    """
    GROQ_API_KEY = os.getenv("GROQ_API_KEY")
    if not GROQ_API_KEY:
        raise RuntimeError("GROQ_API_KEY not set in environment")

    prompt = _build_llm_prompt(guides)

    # langchain_groq 사용 시를 우선 시도
    try:
        from langchain_groq import ChatGroq

        llm = ChatGroq()
        resp = llm.invoke(prompt)
        # langchain_groq의 응답 객체는 `.content` 속성을 가질 수 있음
        return getattr(resp, "content", str(resp))
    except Exception as e:
        logging.warning("[review_guides_with_groq] langchain_groq 호출 실패: %s", e)
        # Groq HTTP API 직접 호출을 시도할 수 있으나, 구현 환경 따라 달라서 여기선 예외로 처리
        raise


def review_guides_with_openai(guides):
    """OpenAI API를 사용해 안내문을 검토한다. 기본 모델은 `gpt-5-mini`.

    - `OPENAI_API_KEY`를 환경변수 또는 .env에서 읽어온다.
    - 실패 시 예외를 발생시켜 최종 폴백으로 이동하게 한다.
    """
    OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
    if not OPENAI_API_KEY:
        raise RuntimeError("OPENAI_API_KEY not set in environment")

    system_and_user_prompt = _build_llm_prompt(guides)

    try:
        import openai

        openai.api_key = OPENAI_API_KEY

        # ChatCompletion (호환성 고려)
        try:
            response = openai.ChatCompletion.create(
                model=OPENAI_REVIEW_MODEL,
                messages=[{"role": "user", "content": system_and_user_prompt}],
                temperature=0
            )
            # 새 버전/클라이언트 호환성
            text = None
            if isinstance(response, dict):
                choices = response.get("choices")
                if choices:
                    text = choices[0].get("message", {}).get("content") or choices[0].get("text")
            else:
                # 객체 응답인 경우
                text = getattr(response.choices[0].message, "content", None)

            return text or str(response)
        except Exception as e:
            # 일부 환경에서는 openai.ChatCompletion 대신 openai.chat.* 사용
            try:
                response = openai.chat.completions.create(
                    model=OPENAI_REVIEW_MODEL,
                    messages=[{"role": "user", "content": system_and_user_prompt}],
                    temperature=0
                )
                return response.choices[0].message.content
            except Exception:
                raise
    except Exception as e:
        logging.warning("[review_guides_with_openai] OpenAI 호출 실패: %s", e)
        raise


def review_guides_with_rules(guides_text: str):
    """간단한 규칙 기반 검토기.

    반환: dict 형태의 검토 결과
    - `summary`: 간단 요약
    - `issues`: 리스트(dict) 각 항목은 `criterion`(1-4)과 `detail`
    - `recommendation`: 수정 권장 문장
    """
    issues = []

    text = guides_text or ""
    summary = text.strip().splitlines()[0][:200] if text.strip() else "(내용 없음)"

    # Criterion 1: 입력 자료에 없는 내용을 단정하는 표현(강한 단정어) 검출
    strong_claims = ["반드시", "항상", "절대", "확실히", "분명히", "틀림없이"]
    if any(word in text for word in strong_claims):
        issues.append({"criterion": 1, "detail": "강한 단정 표현 사용 가능성: '반드시/항상' 등"})

    # Criterion 2: 핵심 정보(날짜, 대상, 행동 지시) 누락 검사(간단히 키워드 기반)
    has_date = any(tok in text for tok in ["년", "월", "일", "날짜", "~"])
    has_target = any(tok in text for tok in ["대상", "누구", "학생", "교수", "직원", "참석자"])
    if not (has_date and has_target):
        missing = []
        if not has_date:
            missing.append("날짜")
        if not has_target:
            missing.append("대상")
        issues.append({"criterion": 2, "detail": f"핵심 정보 누락: {', '.join(missing)}"})

    # Criterion 3: 사용자가 해야 할 일이 보이는가 (명령/행동 키워드)
    action_words = ["해야", "해주세요", "하시기", "준비", "제출", "참석", "신청"]
    if not any(tok in text for tok in action_words):
        issues.append({"criterion": 3, "detail": "사용자 행동(해야 할 일) 명확하지 않음"})

    # Criterion 4: 위험한 표현(안전 우려/과장 등)
    risky = ["위험", "유해", "폭발", "금지", "독성", "심각한 부작용"]
    if any(tok in text for tok in risky):
        issues.append({"criterion": 4, "detail": "안전 관련 또는 위험 표현 포함"})

    recommendation = "검토 결과, 위의 이슈를 참조하여 문구를 명확히 하고 필요 시 날짜/대상/행동 지시를 추가하세요."

    return {
        "summary": summary,
        "issues": issues,
        "recommendation": recommendation
    }
        